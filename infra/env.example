# ============================================================
# Johnr1sh Copilot — Environment Variables Template
# Copy to .env.local and fill in your secrets
# NEVER commit .env.local or .env to source control
# ============================================================

# ---- Next.js / Web ----------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ---- Supabase (server-side) --------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Database ----------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/postgres

# ---- JWT ---------------------------------------------------
# Generate with: openssl rand -base64 64
JWT_SECRET=change-me-to-a-long-random-string

# ---- Replicate AI ------------------------------------------
REPLICATE_API_TOKEN=r8_your_replicate_token

# ---- Upstash Redis -----------------------------------------
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ---- Sentry ------------------------------------------------
SENTRY_DSN=https://your-key@o0.ingest.sentry.io/0
SENTRY_RELEASE=1.0.0
NEXT_PUBLIC_SENTRY_DSN=https://your-key@o0.ingest.sentry.io/0

# ---- Server ------------------------------------------------
PORT=4000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000

# ---- GitHub API (free, authenticated: 5 000 req/hr) --------
# Create a PAT at https://github.com/settings/tokens
# Required scopes: repo, read:org, read:user
GITHUB_TOKEN=ghp_your_personal_access_token

# ---- Seed --------------------------------------------------
SEED_ADMIN_EMAIL=admin@example.com

# ---- Local Docker ------------------------------------------
POSTGRES_PASSWORD=postgres
