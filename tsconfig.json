{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "paths": {
      "@johnr1sh/lib/*": ["./lib/*"],
      "@johnr1sh/ui": ["./ui/index.ts"],
      "@johnr1sh/db": ["./db/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", ".next", "coverage"]
}
